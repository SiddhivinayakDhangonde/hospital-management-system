@model List<HospitalManagment.Models.PatientDetails>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Patient Appointments</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <div class="container mt-5">
        <h2 class="mb-4">Patient Appointment Details</h2>
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>PID</th>
                    <th>Patient Name</th>
                    <th>Date</th>
                    <th>Disease</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var x in Model)
                {
                    <tr>
                        <td>@x.pid</td>
                        <td>@x.pname</td>
                        <td>@x.date</td>
                        <td>@x.disease</td>
                        <td>@x.status</td>
                        <td>
                            <a href="@Url.Action("EditAppointment", "Doctor", new { id = x.pid })" class="btn btn-danger btn-sm">Edit</a>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>
