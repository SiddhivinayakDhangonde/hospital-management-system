@model List<HospitalManagment.Models.DoctorInfo>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Doctor List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #f8f9fa;
            padding: 30px;
        }

        .main-content {
            max-width: 1000px;
            margin: auto;
            background-color: #ffffff;
            padding: 25px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

        header h1 {
            font-size: 2rem;
            margin-bottom: 10px;
        }

        header h2 {
            font-size: 1.2rem;
            color: #28a745;
        }

        .user-info {
            font-size: 1rem;
            margin-bottom: 20px;
            color: #6c757d;
        }

        .doctor-table {
            width: 100%;
        }

            .doctor-table th, .doctor-table td {
                text-align: center;
                vertical-align: middle;
            }

        .btn-primary {
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <main class="main-content">
        <header>
            <h1>Welcome, @Session["name"]</h1>
            <h2>@TempData["messege"]</h2>
            <div class="user-info">Patient ID: @Session["id"]</div>
        </header>

        <table class="table table-bordered table-hover doctor-table">
            <thead class="table-dark">
                <tr>
                    <th>Doctor Name</th>
                    <th>Specialization</th>
                    <th>Phone Number</th>
                    <th>Fees</th>
                    <th>OPD Time</th>
                    <th>Email</th>
                    <th>Book Appointment</th>
                </tr>
            </thead>
            <tbody>
                @{
                    foreach (var x in Model)
                    {
                        <tr>
                            <td>@x.name</td>
                            <td>@x.specialization</td>
                            <td>@x.phonenumber</td>
                            <td>@x.fees</td>
                            <td>@x.time</td>
                            <td>@x.email</td>
                            <td>
                                <a href="/Patient/BookAppointment?id=@x.did" class="btn btn-sm btn-primary">Book Appointment</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </main>
</body>
</html>
