@model HospitalManagment.Models.EditAppointment
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Appointment</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f8;
            padding: 40px;
        }

        .form-container {
            max-width: 400px;
            margin: auto;
            background-color: #fff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

            .form-container h2 {
                text-align: center;
                margin-bottom: 20px;
                color: #333;
            }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin-bottom: 20px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        button {
            width: 100%;
            padding: 10px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
        }

            button:hover {
                background-color: #0056b3;
            }
    </style>
</head>
<body>

    <div class="form-container">
        <h2>Edit Appointment</h2>
        <form action="/Doctor/EditAppointment" method="post">
            <label for="id">Appointment ID</label>
            <input type="number" id="id" name="id" value="@Model.id" readonly>

            <label for="name">Patient Name</label>
            <input type="text" id="name" name="name" value="@Model.name" readonly>

            <label for="date">Date</label>
            <input type="date" id="date" name="date" value="@Model.date">

            <label for="time">Time</label>
            <input type="time" id="time" name="time" value="@Model.time">

            <label for="disease">Disease</label>
            <input type="text" id="disease" name="disease" value="@Model.disease" readonly>

            <label for="status">Status</label>
            <select id="status" name="status" required>
                <option value="">Select status</option>
                <option value="Scheduled" @(Model.status == "Scheduled" ? "selected" : "")>ReScheduled</option>
                <option value="Completed" @(Model.status == "Completed" ? "selected" : "")>Completed</option>
            </select>

            <button type="submit">Update</button>
        </form>
    </div>

</body>
</html>