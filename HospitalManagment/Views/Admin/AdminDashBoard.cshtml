
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #f8f9fa;
        }

        .sidebar {
            height: 100vh;
            background-color: #343a40;
            color: white;
            padding-top: 20px;
        }

            .sidebar a {
                color: white;
                text-decoration: none;
                display: block;
                padding: 10px 20px;
            }

                .sidebar a:hover {
                    background-color: #495057;
                }

        .card-icon {
            font-size: 2rem;
            color: #0d6efd;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 sidebar">
                <h4 class="text-center">Admin Dashboard</h4>
                <a href="/Admin/DoctorsList"> Approve Doctor </a>
                <a href="/Admin/PatientsList">Patients</a>
                <a href="/Doctor/DoctorDetails">Approved Doctors</a>
               
            </div>

            <!-- Main Content -->
            <div class="col-md-10">
                <!-- Navbar -->
                <nav class="navbar navbar-light bg-light mt-2 mb-4">
                    <div class="container-fluid">
                        <span class="navbar-brand mb-0 h1">Welcome, @Session["name"]</span>
                        <a href="/Admin/AdminLogout" class="btn btn-outline-primary">Logout</a>
                    </div>
                </nav>

                <!-- Dashboard Cards -->
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5>Appointments</h5>
                                        <p>Today: 8</p>
                                    </div>
                                    <div class="card-icon">📅</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5> Approved Doctors</h5>
                                        <p>Total: @TempData["doctorcount"] </p>
                                    </div>
                                    <div class="card-icon">🧑‍🤝‍🧑</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5>Pending Approved Doctors</h5>
                                        <p>Total:@TempData["pending"] </p>
                                    </div>
                                    <div class="card-icon">🧑‍🤝‍🧑</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5>Messages</h5>
                                        <p>Unread: 5</p>
                                    </div>
                                    <div class="card-icon">💬</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <footer class="mt-5 text-center text-muted">
                    &copy; 2025 Doctor Dashboard. All rights reserved.
                </footer>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
