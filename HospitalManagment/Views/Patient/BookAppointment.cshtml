@model HospitalManagment.Models.Appointment
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>BookAppointment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <div class="container mt-5">
        <h2>Book Appointment</h2>
        @using (Html.BeginForm("BookAppointment", "Patient", FormMethod.Post))
        {
            <div class="mb-3">
                @Html.LabelFor(model => model.pid, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.pid, new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.pid, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(model => model.did, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.did, new { @class = "form-control", @readonly = "readonly" })
            </div>


            <div class="mb-3">
                @Html.LabelFor(model => model.date, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.date, new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(model => model.date, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(model => model.time, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.time, new { @class = "form-control", type = "time" })
                @Html.ValidationMessageFor(model => model.time, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(model => model.disease, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.disease, new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.disease, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(model => model.status, new { @class = "form-label" })
                @Html.TextBoxFor(model => model.status, new { @class = "form-control",@value="Panding" })
                @Html.ValidationMessageFor(model => model.status, "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="btn btn-primary">Book Appointment</button>
        }
    </div>
</body>
</html>
