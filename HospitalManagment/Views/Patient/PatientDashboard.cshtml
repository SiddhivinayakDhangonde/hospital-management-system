@model List<HospitalManagment.Models.AppointmentSuccess>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Patient Dashboard</title>
    <link rel="stylesheet" href="style.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            padding: 20px;
        }

        .table-container {
            max-width: 900px;
            margin: auto;
        }
    </style>

</head>
<body>
    <div class="dashboard">
        <aside class="sidebar">
            <h2>MyHealth Portal</h2>
            <nav>
                <ul>
                    <li><a href="/Patient/PatientDashboard">Dashboard</a></li>
                    <li><a href="/Doctor/DoctorDetails">Book Appointment</a></li>
                    <li><a href="#">Profile</a></li>
                    <li><a href="/Home/Logout">Logout</a></li>

                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <header>
                <h1>Welcome, @Session["name"]</h1>
                <h2>@TempData["messege"]</h2>
                <div class="user-info">Patient ID:@Session["id"]</div>
            </header>
            <div class="table-container">
                <h2 class="mb-4 text-center">Appointment Details</h2>
                <table class="table table-bordered table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>Appointment Id</th>
                            <th>Appointment Date</th>
                            <th>Appointment Time</th>
                            <th>Appointment Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in Model)
                        {
                            <tr>
                                <td>@x.aid</td>
                                <td>@x.date.ToString()</td>
                                <td>@x.time</td>
                                <td>@x.status</td>
                                <td>


                                    <a href="@Url.Action("CancelAppointment", "Patient", new { id = x.aid })" class="btn btn-danger btn-sm">Cancel</a>


                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>


</body>
</html>

<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background-color: #f4f6f8;
    }

    .dashboard {
        display: flex;
        height: 100vh;
    }

    .sidebar {
        width: 220px;
        background-color: #2f3e46;
        color: #fff;
        padding: 20px;
    }

        .sidebar h2 {
            margin-bottom: 30px;
        }

        .sidebar ul {
            list-style: none;
            padding: 0;
        }

        .sidebar li {
            margin: 15px 0;
        }

        .sidebar a {
            color: #fff;
            text-decoration: none;
        }

    .main-content {
        flex: 1;
        padding: 20px;
    }

    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .user-info {
        font-weight: bold;
    }

    .cards {
        display: flex;
        gap: 20px;
        margin: 20px 0;
    }

    .card {
        background-color: #fff;
        padding: 20px;
        border-radius: 8px;
        flex: 1;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
</style>


